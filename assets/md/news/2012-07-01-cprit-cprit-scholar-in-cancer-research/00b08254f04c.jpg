	var dataLayer = dataLayer || [];</script> <title>13 Key Drivers of the Latino Cancer Burden, According to Researchers - Salud America</title><script data-cfasync="false" id="ao_optimized_gfonts_config">WebFontConfig={google:{families:["Catamaran:400,700,900","Roboto:400,700,900","Roboto Condensed"] },classes:false, events:false, timeout:1500};</script><link rel="canonical" href="https://salud-america.org/13-key-drivers-of-the-latino-cancer-burden-according-to-researchers/" /><meta property="og:locale" content="en_US" /><meta property="og:type" content="article" /><meta property="og:title" content="13 Key Drivers of the Latino Cancer Burden, According to Researchers - Salud America" /><meta property="og:description" content="In the United States, cancer is a significant public health challenge. For example, among Latinos, who are 19.5% of the population, rates are higher and prognoses are poorer than other groups. The Latino cancer burden is driven by complex interactions in 13 key areas, according to a new publication from the Task Force: Latino Researchers &#046;&#046;&#046;" /><meta property="og:url" content="https://salud-america.org/13-key-drivers-of-the-latino-cancer-burden-according-to-researchers/" /><meta property="og:site_name" content="Salud America" /><meta property="article:publisher" content="https://www.facebook.com/SaludToday/" /><meta property="article:published_time" content="2025-08-14T21:07:08+00:00" /><meta property="og:image" content="https://salud-america.org/wp-content/uploads/2025/08/13-drivers-of-cancer-burden.jpg" /><meta property="og:image:width" content="1365" /><meta property="og:image:height" content="768" /><meta property="og:image:type" content="image/jpeg" /><meta name="author" content="Cliff Despres" /><meta name="twitter:card" content="summary_large_image" /><meta name="twitter:creator" content="@SaludAmerica" /><meta name="twitter:site" content="@saludamerica" /><meta name="twitter:label1" content="Written by" /><meta name="twitt